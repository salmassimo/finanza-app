# ============================================================
# Template per la produzione su Synology
# Copia questo file: cp .env.prod.example .env.prod
# Compila tutti i valori (NON committare .env.prod su git!)
# ============================================================

# ── DATABASE ─────────────────────────────────────────────────
# Password per PostgreSQL (inventati una password sicura)
DB_PASSWORD=SCEGLI_UNA_PASSWORD_SICURA

# ── JWT ──────────────────────────────────────────────────────
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=GENERA_UNA_CHIAVE_SEGRETA_HEX_64_CHARS

# ── CORS ─────────────────────────────────────────────────────
# URL pubblico del sito (quello che useranno i browser)
# Es: https://salierno.synology.me  oppure  http://192.168.1.100:19006
ALLOWED_ORIGINS=https://IL_TUO_DOMINIO.synology.me

# ── FRONTEND → BACKEND ───────────────────────────────────────
# URL dell'API backend visto dal browser (non dal container!)
# Se usi reverse proxy path-based: https://tuodominio.synology.me/api/v1
# Se esponi la porta 8000 direttamente: http://192.168.1.100:8000/api/v1
API_URL=https://IL_TUO_DOMINIO.synology.me/api/v1

# ── AI ADVISOR ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-CHIAVE_ANTHROPIC
