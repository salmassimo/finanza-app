# Copia questo file in .env.prod e compila i valori reali

# Database
DATABASE_URL=postgresql+asyncpg://finanza_user:SCEGLI_PASSWORD_DB@db:5432/finanza_db

# JWT - genera con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=SCEGLI_CHIAVE_SEGRETA_LUNGA
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# App
APP_NAME="Finanza Personale"
DEBUG=false

# CORS - URL pubblico del frontend
ALLOWED_ORIGINS=https://IL_TUO_DOMINIO

# AI Advisor
ANTHROPIC_API_KEY=sk-ant-api03-...
